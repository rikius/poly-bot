# ============================================================
# Operating mode: paper (simulated) or live (real money)
# Default is paper — ALWAYS test in paper mode first
# ============================================================
BOT_MODE=paper

# ============================================================
# Polymarket API credentials
# Obtain from https://polymarket.com/profile (API section)
# ============================================================
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# ============================================================
# Ethereum wallet (Polygon network)
# For live mode: wallet must hold USDC on Polygon
# ============================================================
PRIVATE_KEY=0x
WALLET_ADDRESS=0x

# ============================================================
# Polygon RPC URL for on-chain position redemptions.
# Default: https://polygon-rpc.com (public, may rate-limit).
# Recommended: use a dedicated key from Alchemy or QuickNode.
# ============================================================
POLYGON_RPC_URL=

# Set false to disable on-chain redeemPositions() (e.g. when RPC is unavailable)
REDEEM_ENABLED=false

# ============================================================
# Risk limits (USD)
# ============================================================
MAX_BET_USD=100
MAX_POSITION_PER_MARKET_USD=500
MAX_TOTAL_EXPOSURE_USD=2000
MAX_DAILY_LOSS_USD=100
MAX_OPEN_ORDERS=10

# ============================================================
# Market discovery
# Controls which markets the bot monitors and trades.
# ============================================================

# Assets to monitor (comma-separated, case-insensitive).
# Leave empty to monitor all supported assets (BTC, ETH, SOL).
# Examples: MARKET_ASSETS=BTC  |  MARKET_ASSETS=BTC,ETH
MARKET_ASSETS=

# Timeframe for Up/Down markets.
# Must match Polymarket slug convention: 15m, 5m, 1m, etc.
MARKET_TIMEFRAME=15m

# Max number of markets to monitor simultaneously.
MARKET_LIMIT=20

# ============================================================
# Strategy: MathArb (core mathematical arbitrage)
# Trades when YES + NO combined ask price < $1.00, locking in
# a risk-free profit. This is the primary arb strategy.
# Default: true (enabled). Set false to run alpha-only strategies.
# ============================================================
MATH_ARB_ENABLED=true

# ============================================================
# Execution mode
# USE_MAKER_MODE: GTC orders at 0% fees (earns rebates).
# When false, uses taker FAK orders (immediate fill or cancel).
# ============================================================
USE_MAKER_MODE=false

# Price offset in dollars for maker orders placed inside the spread (default 0.005 = 0.5¢)
MAKER_PRICE_OFFSET=0.005

# How long (seconds) a maker GTC order stays live before cancellation
MAKER_ORDER_TTL=120

# ============================================================
# Strategy: MakerRebateArb
# Passive GTC orders that capture the maker rebate when the
# YES + NO combined ask diverges. Complements USE_MAKER_MODE.
# ============================================================
MAKER_REBATE_ENABLED=false

# ============================================================
# Strategy: TemporalArb
# Trades Polymarket binary markets based on real-time Binance
# price moves (e.g. BTC 15-min Up/Down markets).
# Recommended for crypto markets where taker fees are 10%.
# ============================================================
TEMPORAL_ARB_ENABLED=false

# Minimum external price move in basis points to trigger a trade (default 100 = 1%)
TEMPORAL_ARB_THRESHOLD_BPS=100

# Controls how aggressively a price move shifts the probability estimate.
# bps_move / sensitivity = probability shift (default 2000)
TEMPORAL_ARB_SENSITIVITY_BPS=2000

# ============================================================
# Strategy: Contrarian (mean-reversion / fade-the-crowd)
# Buys when a token drops sharply (≥ MIN_MOVE_BPS within
# LOOKBACK_SECS), expecting the market to partially revert.
# Conservative start: MIN_MOVE_BPS=800, MAX_BET_USD=5
# ============================================================
CONTRARIAN_ENABLED=false

# Minimum mid-price drop in basis points within the lookback window to trigger entry
CONTRARIAN_MIN_MOVE_BPS=500

# Rolling time window for velocity measurement (seconds)
CONTRARIAN_LOOKBACK_SECS=60

# Max notional per trade in USDC (defaults to MAX_BET_USD if unset)
CONTRARIAN_MAX_BET_USD=

# Time-based exit: close the position after this many seconds
CONTRARIAN_MAX_HOLD_SECS=120

# Take-profit threshold as a fraction of entry price (0.08 = 8%)
CONTRARIAN_PROFIT_TARGET_PCT=0.08

# Stop-loss threshold as a fraction of entry price (0.05 = 5%)
CONTRARIAN_STOP_LOSS_PCT=0.05

# Minimum edge between complement-implied fair value and ask (standard markets)
CONTRARIAN_MIN_EDGE=0.05

# Minimum edge for high-fee 10%-fee markets (e.g. 15-min crypto)
CONTRARIAN_HIGH_FEE_MIN_EDGE=0.12

# Per-market cooldown after a trade fires (milliseconds)
CONTRARIAN_COOLDOWN_MS=10000

# ============================================================
# Strategy: TBO Trend (Trending Breakout)
# Buys when mid-price breaks above its recent rolling high by
# a threshold and holds that level for several consecutive
# book updates — signals building momentum conviction.
# Conservative start: BREAKOUT_THRESHOLD_BPS=200, MIN_CONFIRM_TICKS=4, MAX_BET_USD=5
# ============================================================
TBO_ENABLED=false

# Number of book-update ticks forming the rolling lookback window (warm-up period)
TBO_LOOKBACK_TICKS=50

# Basis points above the rolling high the current mid must exceed to qualify as a breakout
TBO_BREAKOUT_THRESHOLD_BPS=150

# Consecutive ticks the price must remain above the breakout level before entry
TBO_MIN_CONFIRM_TICKS=3

# Max notional per trade in USDC (defaults to MAX_BET_USD if unset)
TBO_MAX_BET_USD=

# Time-based exit in seconds
TBO_MAX_HOLD_SECS=180

# Take-profit threshold as a fraction of entry price (0.06 = 6%)
TBO_PROFIT_TARGET_PCT=0.06

# Stop-loss threshold as a fraction of entry price (0.04 = 4%)
TBO_STOP_LOSS_PCT=0.04

# Minimum ask-side depth in shares required at time of entry
TBO_MIN_ASK_DEPTH=10

# Per-market cooldown after a trade fires (milliseconds)
TBO_COOLDOWN_MS=15000

# ============================================================
# Strategy: TBT Divergence + Late Entry
# Detects bullish RSI divergence: price makes a lower low but
# the momentum oscillator makes a higher low (seller exhaustion).
# Waits for a small pullback after detection before entering.
# Conservative start: DIVERGENCE_MIN_GAP_BPS=150, PULLBACK_BPS=80, MAX_BET_USD=5
# ============================================================
TBT_ENABLED=false

# Total rolling window in book-update ticks (split evenly into two halves for divergence)
TBT_LOOKBACK_TICKS=80

# Number of price changes used for each RSI computation (default 14)
TBT_RSI_PERIOD=14

# Minimum price gap between old and recent lows in basis points for a valid divergence
TBT_DIVERGENCE_MIN_GAP_BPS=100

# How far (bps) the price must retrace from the detection mid before the entry fires
TBT_PULLBACK_BPS=50

# Ticks to wait for the pullback before the divergence signal expires
TBT_SIGNAL_EXPIRY_TICKS=30

# Max notional per trade in USDC (defaults to MAX_BET_USD if unset)
TBT_MAX_BET_USD=

# Time-based exit in seconds
TBT_MAX_HOLD_SECS=240

# Take-profit threshold as a fraction of entry price (0.07 = 7%)
TBT_PROFIT_TARGET_PCT=0.07

# Stop-loss threshold as a fraction of entry price (0.05 = 5%)
TBT_STOP_LOSS_PCT=0.05

# Minimum ask-side depth in shares required at time of entry
TBT_MIN_ASK_DEPTH=8

# Per-market cooldown after a trade fires (milliseconds)
TBT_COOLDOWN_MS=20000

# ============================================================
# Strategy: Late Entry (High-Confidence Near-Resolution)
# Buys a near-certain outcome in the final minutes before
# market resolution to harvest a small, high-probability gain.
# Example: BTC Up/Down market with 2 min left, YES at 0.96 →
#   buy YES for a ~4% return if the outcome holds.
# Risk: black-swan reversal in the final minutes.
# Conservative start: MAX_ENTRY_PRICE=0.03, MAX_BET_USD=50,
#   ENTRY_WINDOW_SECS=180 (last 3 min only)
# ============================================================
LATE_ENTRY_ENABLED=false

# Fraction of the round remaining when the strategy activates (0.0–1.0).
# Scales automatically with market timeframe:
#   15-min (900s) × 0.20 = last 180s (3 min)
#    5-min (300s) × 0.20 = last  60s (1 min)
#    1-min  (60s) × 0.20 = last  12s
LATE_ENTRY_WINDOW_PCT=0.40

# Minimum ask price of the winning token to buy.
# We buy the near-certain winner (high ask = high probability of paying $1).
# 0.90 = 11% gross return (net ~1% after 10% fee), 0.92 = safer threshold
LATE_ENTRY_MIN_ENTRY_PRICE=0.90

# Max notional per trade in USDC (defaults to MAX_BET_USD if unset)
LATE_ENTRY_MAX_BET_USD=

# Minimum ask-side depth in shares required at time of entry
LATE_ENTRY_MIN_ASK_DEPTH=5

# Per-market cooldown in milliseconds (prevents re-entering the same round)
# Default 120000 = 2 min, which covers most of the entry window
LATE_ENTRY_COOLDOWN_MS=120000

# Stop-loss: sell if the held token's bid drops to or below this price (0 = disabled)
# Entry at 0.90 → stop at 0.70 caps max loss at ~22% of notional
LATE_ENTRY_STOP_LOSS_PRICE=0.70

# ============================================================
# Alerting
# Supported backends: discord, telegram
# Leave ALERT_BACKEND unset (or empty) to disable alerts.
# ============================================================
ALERT_BACKEND=

# Discord: set ALERT_BACKEND=discord and paste your webhook URL
DISCORD_WEBHOOK_URL=

# Telegram: set ALERT_BACKEND=telegram and fill both values
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# API server
# The bot exposes a REST/WebSocket API used by the frontend.
# ============================================================
API_PORT=3001

# ============================================================
# Logging
# Options: error, warn, info, debug, trace
# ============================================================
RUST_LOG=info
