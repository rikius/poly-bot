# ============================================================
# Operating mode: paper (simulated) or live (real money)
# Default is paper — ALWAYS test in paper mode first
# ============================================================
BOT_MODE=paper

# ============================================================
# Polymarket API credentials
# Obtain from https://polymarket.com/profile (API section)
# ============================================================
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# ============================================================
# Ethereum wallet (Polygon network)
# For live mode: wallet must hold USDC on Polygon
# ============================================================
PRIVATE_KEY=0x
WALLET_ADDRESS=0x

# ============================================================
# Risk limits (USD)
# ============================================================
MAX_BET_USD=100
MAX_POSITION_PER_MARKET_USD=500
MAX_TOTAL_EXPOSURE_USD=2000
MAX_DAILY_LOSS_USD=100
MAX_OPEN_ORDERS=10

# ============================================================
# Strategy settings
# ============================================================
# Use maker execution (GTC orders, 0% fees, earns rebates).
# When false, uses taker FOK orders (immediate fill or cancel).
USE_MAKER_MODE=false

# Price offset in dollars for maker orders placed inside the spread (default 0.005 = 0.5¢)
MAKER_PRICE_OFFSET=0.005

# How long (seconds) a maker GTC order stays live before cancellation
MAKER_ORDER_TTL=120

# Enable MakerRebateArbStrategy: passive GTC orders that capture the maker rebate
# when YES + NO spread diverges. Complements USE_MAKER_MODE.
MAKER_REBATE_ENABLED=false

# ============================================================
# Temporal arb strategy
# Trades Polymarket binary markets based on real-time Binance
# price moves (e.g. BTC 15-min Up/Down markets).
# Recommended for crypto markets where math-arb fees are 10%.
# ============================================================
TEMPORAL_ARB_ENABLED=false

# Minimum external price move in basis points to trigger a trade (default 100 = 1%)
TEMPORAL_ARB_THRESHOLD_BPS=100

# Controls how aggressively a price move shifts the probability estimate.
# bps_move / sensitivity = probability shift (default 2000)
TEMPORAL_ARB_SENSITIVITY_BPS=2000

# ============================================================
# Alerting
# Supported backends: discord, telegram
# Leave ALERT_BACKEND unset (or empty) to disable alerts.
# ============================================================
ALERT_BACKEND=

# Discord: set ALERT_BACKEND=discord and paste your webhook URL
DISCORD_WEBHOOK_URL=

# Telegram: set ALERT_BACKEND=telegram and fill both values
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# API server
# The bot exposes a REST/WebSocket API used by the frontend.
# ============================================================
API_PORT=3001

# ============================================================
# Logging
# Options: error, warn, info, debug, trace
# ============================================================
RUST_LOG=info
